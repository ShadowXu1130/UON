<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="UON.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:UON.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Shell.BackgroundColor="#000000"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White"
    Shell.UnselectedColor="#8E8E93"
    Shell.TabBarBackgroundColor="#2C2C2E"
    Shell.TabBarForegroundColor="White"
    Shell.TabBarUnselectedColor="#8E8E93"
    Shell.TabBarTitleColor="White">

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage"
        Shell.TabBarIsVisible="False" />

    <TabBar Route="main">
        <Tab Title="Home" Icon="home.png">
            <ShellContent ContentTemplate="{DataTemplate views:HomePage}" />
        </Tab>
        <Tab Title="Timetable" Icon="calendar.png">
            <ShellContent ContentTemplate="{DataTemplate views:TimetablePage}" />
        </Tab>
    </TabBar>
</Shell>