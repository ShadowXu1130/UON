<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UON.Views.LoginPage"
             BackgroundColor="#121212">

    <VerticalStackLayout Spacing="15" 
                         VerticalOptions="Center" 
                         HorizontalOptions="Center"
                         Padding="20">

        <Image Source="uon_logo.png" 
               HeightRequest="120" 
               HorizontalOptions="Center" 
               Margin="0,0,0,20"/>

        <Label Text="UON Access" 
               FontSize="32" 
               FontAttributes="Bold" 
               TextColor="White" 
               HorizontalOptions="Center" />

        <Label Text="Sign in with your university account" 
               FontSize="14"
               TextColor="#A0A0A0" 
               HorizontalOptions="Center" 
               Margin="0,0,0,20"/>

        <Button Text="Sign in with Microsoft" 
                ImageSource="ms_logo.png"
                ContentLayout="Left, 15" 
                BackgroundColor="#252525"
                BorderColor="#404040"
                BorderWidth="1"
                CornerRadius="8"
                WidthRequest="300" 
                HeightRequest="50"
                TextColor="White"
                FontSize="16"
                Clicked="OnLoginButtonClicked" />

        <Button Text="Skip Login (Test Mode Only)" 
                BackgroundColor="#1A1A1A"
                BorderColor="#333333"
                BorderWidth="1"
                CornerRadius="8"
                WidthRequest="300" 
                HeightRequest="40"
                TextColor="#888888"
                FontSize="14"
                Clicked="OnTestModeClicked" />

        <Label Text="Only student and teacher in University of newcastle are permitted" 
               FontSize="11"
               TextColor="#666666" 
               HorizontalOptions="Center" 
               Margin="0,10,0,0"/>

    </VerticalStackLayout>
</ContentPage>