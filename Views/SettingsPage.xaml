<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UON.Views.SettingsPage"
             BackgroundColor="Black"
             Title="Settings"
             Shell.NavBarIsVisible="False">

    <VerticalStackLayout Padding="25" Spacing="30">
        <HorizontalStackLayout Spacing="10">
            <Label Text="&lt;" TextColor="White" FontSize="20" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Label.GestureRecognizers>
            </Label>
            <Label Text="Back" TextColor="White" FontSize="18" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>

        <Label Text="Settings" TextColor="White" FontSize="32" FontAttributes="Bold" />

        <HorizontalStackLayout Spacing="20" VerticalOptions="Center">
            <Border StrokeShape="RoundRectangle 35" WidthRequest="70" HeightRequest="70" BackgroundColor="#252525">
                <Label Text="👤" HorizontalOptions="Center" VerticalOptions="Center" FontSize="35" />
            </Border>
            <VerticalStackLayout VerticalOptions="Center">
                <Label x:Name="UserNameLabel" Text="Xinpeng Xu" TextColor="White" FontSize="20" FontAttributes="Bold" />
                <Label x:Name="UserEmailLabel" Text="Xinpeng.Xu@psba.edu.sg" TextColor="#A0A0A0" FontSize="14" />
            </VerticalStackLayout>
        </HorizontalStackLayout>

        <Border BackgroundColor="#1A1A1A" StrokeShape="RoundRectangle 12" StrokeThickness="0" HeightRequest="55">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnLogOutClicked" />
            </Border.GestureRecognizers>
            <Label Text="Log Out" TextColor="#FF4B4B" HorizontalOptions="Center" VerticalOptions="Center" FontSize="18" FontAttributes="Bold" />
        </Border>
    </VerticalStackLayout>
</ContentPage>